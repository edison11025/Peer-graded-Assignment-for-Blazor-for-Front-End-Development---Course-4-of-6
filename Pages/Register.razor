@page "/events/{id:int}/register"
@using System.ComponentModel.DataAnnotations
@using EventEase.Models
@using EventEaseApp2.Services
@inject EventService EventService
@inject UserSessionService Session
@inject NavigationManager NavManager

<h2>Register for Event</h2>

@if (Event != null)
{
    <EditForm Model="@Registration" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger">@ErrorMessage</div>
        }

        <div class="form-group">
            <label>Name:</label>
            <InputText @bind-Value="Registration.Name" class="form-control" />
            <ValidationMessage For="@(() => Registration.Name)" />
        </div>

        <div class="form-group">
            <label>Email:</label>
            <InputText @bind-Value="Registration.Email" class="form-control" />
            <ValidationMessage For="@(() => Registration.Email)" />
        </div>

        <div class="form-group">
            <label>Attendees:</label>
            <InputNumber @bind-Value="Registration.Attendees" class="form-control" />
            <ValidationMessage For="@(() => Registration.Attendees)" />
        </div>

        <button type="submit" class="btn btn-success">Submit</button>
    </EditForm>

 @if (Session.IsLoggedIn)
    {
        <h4 class="mt-3">Session Info:</h4>
        <p>Logged in as: <strong>@Session.UserName</strong> (@Session.Email)</p>
    }


    <h4 class="mt-3">Current Attendees:</h4>
    <ul>
        @foreach (var attendee in EventService.GetAttendance(id))
        {
            <li>@attendee</li>
        }
    </ul>
}
else
{
    <p>Event not found.</p>
}

@code {
    [Parameter] public int id { get; set; }
    private EventModel? Event;
    private RegistrationModel Registration = new();
    private string ErrorMessage = string.Empty;

    protected override void OnInitialized()
    {
        // Mock lookup
        Event = new EventModel
        {
            Id = id,
            Name = "Sample Event",
            Date = DateTime.Now,
            Location = "Sample Location"
        };
    }

    private void HandleValidSubmit()
    {
        try
        {
            ErrorMessage = string.Empty;
            // Save session info
            Session.StartSession(Registration.Name, Registration.Email);
            // Register attendance
            EventService.RegisterAttendance(id, Registration.Name);
            
            // Clear the form by resetting the model
        Registration = new RegistrationModel();
            NavManager.NavigateTo($"/events/{id}");
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    public class RegistrationModel
    {
        [Required(ErrorMessage = "Name is required")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Invalid email format")]
        public string Email { get; set; } = string.Empty;

        [Range(1, 10, ErrorMessage = "Attendees must be between 1 and 10")]
        public int Attendees { get; set; }
    }
}